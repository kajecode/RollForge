{
  "name": "rollforge",
  "version": "2.2.1",
  "description": "",
  "main": "index.js",
  "keywords": [],
  "author": "Karlan Talkington <kbtalkin@gmail.com>",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json && tsc-esm-fix dist",
    "register": "tsx src/commands/registerCommands.ts",
    "ingest": "tsx src/ingest/ingest.ts ./corpus twilight-veil",
    "ingest:prune": "tsx src/ingest/ingest.ts ./corpus twilight-veil --prune",
    "ingest:dry-run": "tsx src/ingest/ingest.ts ./corpus twilight-veil --dry-run",
    "ingest:srd": "tsx src/ingest/load_srd.ts",
    "import:prices": "tsx src/ingest/importPrices.ts ./data/5e-SRD-Items.csv",
    "dump": "tsx src/dumpToJson.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.mjs\"",
    "validate:atlas": "node scripts/validate-atlas-indexes.mjs"
  },
  "dependencies": {
    "@dice-roller/rpg-dice-roller": "^5.5.1",
    "discord.js": "14.26.3",
    "dotenv": "17.3.1",
    "fast-csv": "^5.0.5",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "mongodb": "7.1.1",
    "mongoose": "9.3.2",
    "openai": "6.32.0",
    "p-limit": "^7.3.0",
    "winston": "3.17.0",
    "winston-transport": "^4.9.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "ts-node": "10.9.1",
    "tsc-alias": "^1.8.16",
    "tsc-esm-fix": "^3.1.2",
    "tsconfig-paths": "4.2.0",
    "tsconfig-paths-webpack-plugin": "4.2.0",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "vite": "8.0.8",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.1",
      "mathjs": "15.2.0",
      "picomatch": "2.3.2",
      "vite": "8.0.8"
    }
  }
}
